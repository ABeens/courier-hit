---
/*
  /preguntas-frecuentes — FAQ del sitio público.

  El acordeón usa <details>/<summary> nativo: cero JavaScript y accesible por
  teclado. El atributo `name` compartido hace que solo una respuesta quede
  abierta a la vez (donde el navegador lo soporte; si no, degrada a varias
  abiertas).

  100% estático: cero JavaScript en el cliente.
*/
import Base from '../layouts/Base.astro';
import Nav from '../components/landing/Nav.astro';
import PageHead from '../components/landing/PageHead.astro';
import CTA from '../components/landing/CTA.astro';
import Footer from '../components/landing/Footer.astro';
import Icon from '../components/ui/Icon.astro';
import { FAQ } from '../data/faq';
---
<Base
  title="Preguntas frecuentes · HS Global Courier"
  description="Resolvemos las dudas más comunes sobre casillero en Miami, carga aérea y marítima, tracking, aduana y seguros de carga."
>
  <Nav />
  <main>
    <PageHead
      eyebrow="Preguntas frecuentes"
      icon="help"
      title="Resolvemos tus dudas"
      sub="Lo que más nos preguntan sobre casillero, carga internacional y aduanas."
    />

    <section class="faq wrap">
      <div class="faq__list">
        {FAQ.map((item) => (
          <details class="faq__item" name="faq">
            <summary class="faq__q">
              <span>{item.q}</span>
              <span class="faq__chev"><Icon name="chevD" size={18} /></span>
            </summary>
            <div class="faq__a">
              <p>{item.a}</p>
              {item.points && (
                <ul class="faq__points">
                  {item.points.map((p) => (
                    <li><Icon name="check" size={15} color="var(--brand)" />{p}</li>
                  ))}
                </ul>
              )}
            </div>
          </details>
        ))}
      </div>

      <div class="faq__foot">
        <p class="muted faq__foot-text">¿Te quedó una duda por fuera?</p>
        <a href="/#contacto" class="btn btn-ghost">
          Habla con un asesor<Icon name="arrowR" size={16} />
        </a>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Base>

<style>
  .faq { padding-top: 56px; padding-bottom: 80px; }

  .faq__list {
    max-width: 820px; margin: 0 auto;
    display: flex; flex-direction: column; gap: 12px;
  }

  .faq__item {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    box-shadow: var(--sh-1);
    transition: border-color .18s ease, box-shadow .18s ease;
  }
  .faq__item:hover { border-color: var(--brand-soft); }
  .faq__item[open] { border-color: var(--brand-soft); box-shadow: var(--sh-2); }

  .faq__q {
    display: flex; align-items: center; justify-content: space-between; gap: 20px;
    padding: 20px 24px; cursor: pointer; list-style: none;
    font-family: var(--font-display);
    font-size: 16.5px; font-weight: 600; color: var(--ink); line-height: 1.35;
  }
  /* Oculta el triángulo nativo (Safari usa ::-webkit-details-marker). */
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::marker { content: ''; }
  .faq__q:focus-visible { outline: 2px solid var(--brand); outline-offset: -2px; border-radius: var(--r-lg); }

  .faq__chev {
    flex-shrink: 0; width: 30px; height: 30px; border-radius: 50%;
    display: grid; place-items: center;
    background: var(--paper-2); color: var(--ink-2);
    transition: transform .22s cubic-bezier(.2,.7,.3,1), background .18s ease, color .18s ease;
  }
  .faq__item[open] .faq__chev {
    transform: rotate(180deg);
    background: var(--brand-soft); color: var(--brand);
  }

  .faq__a { padding: 0 24px 22px; max-width: 660px; }
  .faq__a p { color: var(--muted); font-size: 15px; line-height: 1.65; }

  .faq__points {
    list-style: none; margin: 14px 0 0; padding: 0;
    display: flex; flex-direction: column; gap: 9px;
  }
  .faq__points li {
    display: flex; align-items: center; gap: 10px;
    font-size: 14.5px; color: var(--ink-2);
  }
  .faq__points :global(svg) { flex-shrink: 0; }

  .faq__foot {
    display: flex; align-items: center; justify-content: center; gap: 16px;
    margin-top: 40px; flex-wrap: wrap;
  }
  .faq__foot-text { font-size: 15px; }

  @media (max-width: 560px) {
    .faq__q { padding: 17px 18px; font-size: 15.5px; gap: 12px; }
    .faq__a { padding: 0 18px 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq__chev { transition: none; }
  }
</style>

---
/*
  Cascara del portal (Opción B, docs/00 §4 y docs/06 §8). Ruta estatica /app que
  monta la ÚNICA isla-app React del portal; ella lleva su propio router y estado
  en cliente. Sin SSR (client:only): es zona privada tras login.

  Nota: la navegacion entre pantallas es en cliente (la URL se queda en /app). Cuando
  se quieran deep-links (/app/usuarios) se reintroduce un catch-all + fallback del host.
*/
import Base from '../../layouts/Base.astro';
import PortalApp from '../../portal/PortalApp';
---

<Base title="Portal · HS Global Courier">
  <PortalApp client:only="react" />
</Base>

---
/*
  HowItWorks — los cuatro pasos del servicio.
*/
import Icon from '../ui/Icon.astro';

const steps = [
  { icon: 'user', title: 'Crea tu casillero', desc: 'Regístrate y recibe tu dirección de Miami al instante, sin costo.' },
  { icon: 'cart', title: 'Compra y prealerta', desc: 'Compra en cualquier tienda y avísanos qué viene en camino.' },
  { icon: 'truck', title: 'Procesamos y enviamos', desc: 'Recibimos, consolidamos y despachamos hacia tu país.' },
  { icon: 'home', title: 'Recibe en casa', desc: 'Paga en línea y te lo entregamos en la puerta de tu hogar.' },
];
---
<section class="how wrap">
  <header class="how__head">
    <span class="chip"><Icon name="zap" size={13} color="var(--brand)" />Cómo funciona</span>
    <h2 class="how__title">Tu compra, en cuatro pasos</h2>
    <p class="muted how__lead">
      Sin complicaciones, sin sorpresas. Tú compras, nosotros nos encargamos del resto.
    </p>
  </header>

  <div class="how__grid">
    {steps.map((s, i) => (
      <article class="card how__card">
        <span class="how__num mono">0{i + 1}</span>
        <span class="how__ic"><Icon name={s.icon} size={22} color="#fff" /></span>
        <div class="how__card-title">{s.title}</div>
        <p class="muted how__card-desc">{s.desc}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .how { padding-top: 80px; padding-bottom: 80px; }
  .how__head { text-align: center; max-width: 620px; margin: 0 auto 52px; }
  .how__title { font-size: 38px; margin-top: 16px; letter-spacing: -.03em; }
  .how__lead { font-size: 16px; margin-top: 12px; }

  .how__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .how__card { padding: 24px; position: relative; }
  .how__num {
    position: absolute; top: 18px; right: 20px; font-size: 13px; font-weight: 700;
    color: var(--brand-soft); -webkit-text-stroke: 1px var(--brand);
  }
  .how__ic {
    width: 46px; height: 46px; border-radius: 13px; background: var(--brand);
    display: grid; place-items: center; margin-bottom: 18px; box-shadow: var(--sh-brand);
  }
  .how__card-title { font-weight: 700; font-size: 16.5px; margin-bottom: 7px; font-family: var(--font-display); }
  .how__card-desc { font-size: 14px; line-height: 1.55; }

  @media (max-width: 900px) { .how__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .how__grid { grid-template-columns: 1fr; } }
</style>

---
/*
  Hero — banner principal. Texto a la izquierda e imagen a la derecha.
  En móvil se apilan (imagen arriba, texto abajo).
*/
import { Image } from 'astro:assets';
import Icon from '../ui/Icon.astro';
import mainBanner from '../../assets/images/main-banner.png';

const features = [
  { icon: 'plane', title: 'Vuelos todos los días', sub: 'Salidas diarias desde Miami' },
  { icon: 'scale', title: 'Tarifa por peso real', sub: 'Pagas solo lo que pesa, sin sorpresas' },
  { icon: 'pin', title: 'Dirección de Miami Tax Free', sub: 'Compra sin impuestos de estado' },
];
---
<section class="hero">
  <div class="hero__inner wrap">
    <div class="hero__media fadeUp">
      <Image
        class="hero__img"
        src={mainBanner}
        alt=""
        widths={[360, 520, 640, 960]}
        sizes="(max-width: 680px) 92vw, 580px"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <div class="hero__copy fadeUp">
      <span class="hero__eyebrow">
        <span class="hero__eyebrow-dot"></span>¿Por qué HS Global?
      </span>

      <ul class="hero__features">
        {features.map((f) => (
          <li class="hero__feature">
            <span class="hero__feature-ic"><Icon name={f.icon} size={22} color="#fff" /></span>
            <span class="hero__feature-body">
              <span class="hero__feature-title">{f.title}</span>
              <span class="hero__feature-sub">{f.sub}</span>
            </span>
          </li>
        ))}
      </ul>

      <p class="hero__lead">
        Nos encargamos de todo: logística, tracking y entrega.
        <strong>Tú solo enfócate en tu negocio.</strong>
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(180deg, var(--brand-softer), var(--paper) 70%);
  }
  .hero__inner {
    padding-top: 56px; padding-bottom: 56px;
    display: grid; grid-template-columns: 0.9fr minmax(0, 580px); gap: 48px;
    align-items: center;
  }
  /* Imagen a la derecha, texto a la izquierda (el orden del DOM deja la
     imagen arriba cuando se apila en móvil). */
  .hero__copy { grid-column: 1; grid-row: 1; }
  .hero__media { grid-column: 2; grid-row: 1; }

  .hero__img {
    width: 100%; height: auto; display: block;
    border-radius: var(--r-lg); box-shadow: var(--sh-3);
  }

  /* Eyebrow */
  .hero__eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-display);
    font-size: 12.5px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase;
    color: var(--brand-600);
    background: var(--surface);
    border: 1px solid var(--brand-soft);
    padding: 7px 14px; border-radius: var(--r-pill);
    box-shadow: var(--sh-1);
    margin-bottom: 24px;
  }
  .hero__eyebrow-dot {
    width: 7px; height: 7px; border-radius: 99px; background: var(--brand);
    box-shadow: 0 0 0 4px oklch(0.55 0.20 263 / .18);
  }

  /* Ganchos */
  .hero__features {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 14px;
  }
  .hero__feature {
    position: relative; overflow: hidden;
    display: flex; align-items: flex-start; gap: 16px;
    padding: 16px 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    box-shadow: var(--sh-1);
    transition: transform .22s cubic-bezier(.2,.7,.3,1),
                box-shadow .22s ease, border-color .22s ease;
  }
  /* Barra de acento a la izquierda que aparece en hover */
  .hero__feature::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, var(--brand), var(--brand-700));
    transform: scaleY(0); transform-origin: center;
    transition: transform .22s ease;
  }
  .hero__feature:hover {
    transform: translateY(-3px);
    box-shadow: var(--sh-2);
    border-color: var(--brand-soft);
  }
  .hero__feature:hover::before { transform: scaleY(1); }

  .hero__feature-ic {
    width: 48px; height: 48px; flex-shrink: 0;
    display: grid; place-items: center;
    border-radius: var(--r-md);
    background: var(--brand); /* respaldo sólido por si el degradado no aplica */
    background: linear-gradient(140deg, var(--brand), var(--brand-700));
    box-shadow: var(--sh-brand);
    transition: transform .22s cubic-bezier(.2,.7,.3,1);
  }
  .hero__feature-ic :global(svg) { display: block; }
  .hero__feature:hover .hero__feature-ic { transform: scale(1.06) rotate(-3deg); }

  .hero__feature-body { display: flex; flex-direction: column; gap: 2px; }
  .hero__feature-title {
    font-family: var(--font-display);
    font-size: 17px; font-weight: 600; color: var(--ink);
    letter-spacing: -0.01em; line-height: 1.2;
  }
  .hero__feature-sub {
    font-size: 13.5px; color: var(--muted); line-height: 1.35;
  }

  .hero__lead {
    margin-top: 26px;
    font-size: 16.5px; line-height: 1.6; color: var(--muted); max-width: 480px;
  }
  .hero__lead strong { color: var(--ink); font-weight: 700; }

  @media (max-width: 680px) {
    .hero__inner {
      grid-template-columns: 1fr; gap: 32px;
      padding-top: 40px; padding-bottom: 40px;
    }
    /* Reset del posicionamiento de escritorio para que se apilen
       (imagen arriba, texto abajo) en una sola columna. */
    .hero__copy, .hero__media { grid-column: 1; grid-row: auto; }
    .hero__media { max-width: 480px; margin: 0 auto; }
  }
</style>

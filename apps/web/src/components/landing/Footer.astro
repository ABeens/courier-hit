---
/*
  Footer — pie del sitio público, fondo oscuro.
*/
import Logo from '../ui/Logo.astro';
import Icon from '../ui/Icon.astro';
import { SERVICES } from '../../data/services';

const cols = [
  {
    /* Los servicios no tienen página propia: se describen en la sección del
       landing, así que todos los nombres llevan allí. */
    title: 'Servicios',
    items: SERVICES.slice(0, 5).map((s) => ({ label: s.name, href: '/#servicios' })),
  },
  {
    title: 'Empresa',
    items: [
      { label: 'Quiénes somos', href: '/#quienes-somos' },
      { label: 'Servicios', href: '/#servicios' },
      { label: 'Preguntas frecuentes', href: '/preguntas-frecuentes' },
      { label: 'Contacto', href: '/#contacto' },
    ],
  },
  {
    title: 'Legal',
    items: [
      { label: 'Términos de uso', href: '/legal/terminos' },
      { label: 'Política de privacidad', href: '/legal/privacidad' },
      { label: 'Iniciar sesión', href: '/app' },
    ],
  },
];
---
<footer class="ft">
  <div class="ft__inner wrap">
    <div class="ft__grid">
      <div>
        <Logo size={46} dark />
        <p class="ft__pitch">
          Tu casillero en Miami y tu operador de carga: paquetería, consolidado aéreo y
          marítimo, aduana y seguro, hasta la puerta de tu casa.
        </p>
        <div class="ft__chips">
          <span class="chip ft__chip"><Icon name="shield" size={13} />Pagos seguros</span>
          <span class="chip ft__chip"><Icon name="globe" size={13} />Cobertura global</span>
        </div>
      </div>

      {cols.map((c) => (
        <div>
          <div class="ft__col-title">{c.title}</div>
          <div class="ft__links">
            {c.items.map((it) => <a href={it.href} class="ft__link">{it.label}</a>)}
          </div>
        </div>
      ))}
    </div>

    <div class="ft__bottom">
      <span>© 2026 HS Global Ltd · Miami · Bogotá</span>
      <span>info@hsgloballtd.com · +1 (555) 010-0000</span>
    </div>
  </div>
</footer>

<style>
  .ft { background: var(--dark); color: var(--on-dark); }
  .ft__inner { padding-top: 64px; padding-bottom: 36px; }
  .ft__grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 40px; }
  .ft__pitch { color: var(--on-dark-muted); font-size: 14px; margin-top: 18px; max-width: 280px; line-height: 1.6; }
  .ft__chips { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
  .ft__chip { background: var(--dark-2); border: 1px solid var(--dark-line); color: var(--on-dark); }

  .ft__col-title {
    font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--on-dark-muted); margin-bottom: 16px;
  }
  .ft__links { display: flex; flex-direction: column; gap: 11px; }
  .ft__link { font-size: 14px; color: var(--on-dark); opacity: .85; }
  .ft__link:hover { opacity: 1; color: #fff; }

  .ft__bottom {
    border-top: 1px solid var(--dark-line); margin-top: 48px; padding-top: 24px;
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
    font-size: 13px; color: var(--on-dark-muted);
  }

  @media (max-width: 820px) { .ft__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .ft__grid { grid-template-columns: 1fr; } }
</style>

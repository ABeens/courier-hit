---
/*
  Services — catálogo completo de servicios, en el landing.
*/
import Icon from '../ui/Icon.astro';
import ServiceCard from '../ui/ServiceCard.astro';
import { SERVICES } from '../../data/services';
---
<section class="svcs" id="servicios">
  <div class="svcs__inner wrap">
    <header class="svcs__head">
      <span class="chip"><Icon name="layers" size={13} color="var(--brand)" />Servicios</span>
      <h2 class="svcs__title">Todo lo que necesitas para importar</h2>
      <p class="muted svcs__lead">
        De la recolección en Estados Unidos a la consolidación, el transporte,
        la aduana y el seguro. Un solo operador para toda la cadena.
      </p>
    </header>

    <div class="svcs__grid">
      {SERVICES.map((s) => <ServiceCard service={s} />)}
    </div>
  </div>
</section>

<style>
  /* scroll-margin: el nav es sticky (70px) y taparía el borde superior al
     llegar desde /#servicios. */
  .svcs { background: var(--paper-2); border-top: 1px solid var(--line); scroll-margin-top: 70px; }
  .svcs__inner { padding-top: 80px; padding-bottom: 80px; }
  .svcs__head { margin-bottom: 36px; }
  .svcs__title { font-size: 38px; margin-top: 16px; letter-spacing: -.03em; }
  .svcs__lead { font-size: 16px; margin-top: 12px; max-width: 520px; line-height: 1.6; }
  .svcs__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }

  @media (max-width: 1100px) { .svcs__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) { .svcs__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) {
    .svcs__grid { grid-template-columns: 1fr; }
    .svcs__title { font-size: 30px; }
  }
</style>

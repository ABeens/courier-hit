---
/*
  Contact — sección de contacto del landing (destino de /#contacto).

  Dos columnas: a la izquierda los datos de contacto directos (correo, teléfono,
  oficinas); a la derecha un formulario de contacto.

  OJO: los datos de contacto se toman del footer y están por confirmar (el
  teléfono es un placeholder del prototipo).

  El formulario NO tiene backend todavía: el envío se intercepta con JS y solo
  muestra una confirmación en pantalla (ver <script>). Cuando exista el endpoint
  de correo, hacer el POST en el punto marcado con TODO.
*/
import Icon from '../ui/Icon.astro';

const contact = [
  { icon: 'mail', label: 'Correo', value: 'info@hsgloballtd.com', href: 'mailto:info@hsgloballtd.com' },
  { icon: 'phone', label: 'Teléfono', value: '+1 (555) 010-0000', href: 'tel:+15550100000' },
  { icon: 'pin', label: 'Oficinas', value: 'Miami, EE. UU. · Bogotá, Colombia', href: null },
];
---
<section class="ctc" id="contacto">
  <div class="ctc__inner wrap">
    <header class="ctc__head">
      <span class="chip"><Icon name="mail" size={13} color="var(--brand)" />Contacto</span>
      <h2 class="ctc__title">Hablemos de tu envío</h2>
      <p class="muted ctc__lead">
        Para cotizar necesitamos origen y destino, peso y dimensiones, tipo de mercancía,
        fecha estimada y valor comercial si aplica.
      </p>
    </header>

    <div class="ctc__grid">
      <aside class="card ctc__info">
        <h3 class="ctc__info-title">Datos de contacto</h3>
        <ul class="ctc__list">
          {contact.map((c) => {
            const Tag = c.href ? 'a' : 'div';
            return (
              <li>
                <Tag href={c.href} class={`ctc__row-item${c.href ? ' is-link' : ''}`}>
                  <span class="ctc__ic"><Icon name={c.icon} size={18} color="var(--brand)" /></span>
                  <span class="ctc__row-text">
                    <span class="ctc__label">{c.label}</span>
                    <span class="ctc__value">{c.value}</span>
                  </span>
                </Tag>
              </li>
            );
          })}
        </ul>
        <p class="ctc__info-note muted">
          Respondemos en horario laboral (Miami · Bogotá). Para cotizar, incluye
          los detalles de tu envío en el mensaje.
        </p>
      </aside>

      <form class="card ctc__form" data-contact-form novalidate>
        <h3 class="ctc__form-title">Escríbenos</h3>
        <div class="ctc__row">
          <div class="ctc__f">
            <label class="field-label" for="ctc-name">Nombre</label>
            <input class="input" id="ctc-name" name="name" type="text" autocomplete="name" placeholder="Tu nombre" required />
          </div>
          <div class="ctc__f">
            <label class="field-label" for="ctc-email">Correo</label>
            <input class="input" id="ctc-email" name="email" type="email" autocomplete="email" placeholder="tu@correo.com" required />
          </div>
        </div>

        <div class="ctc__f">
          <label class="field-label" for="ctc-phone">Teléfono <span class="faint">(opcional)</span></label>
          <input class="input" id="ctc-phone" name="phone" type="tel" autocomplete="tel" placeholder="+57 300 000 0000" />
        </div>

        <div class="ctc__f">
          <label class="field-label" for="ctc-message">Mensaje</label>
          <textarea class="input" id="ctc-message" name="message" rows="4" placeholder="Cuéntanos qué necesitas enviar: origen y destino, peso y dimensiones, tipo de mercancía…" required></textarea>
        </div>

        <div class="ctc__actions">
          <button class="btn btn-primary" type="submit" data-contact-submit>
            <Icon name="send" size={17} color="#fff" />
            Enviar mensaje
          </button>
          <p class="ctc__note faint" data-contact-status role="status" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  /* scroll-margin: el nav es sticky (70px) y taparía el borde superior al
     llegar desde /#contacto. */
  .ctc {
    background: var(--paper-2);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    scroll-margin-top: 70px;
  }
  .ctc__inner { padding-top: 72px; padding-bottom: 72px; }
  .ctc__head { text-align: center; max-width: 620px; margin: 0 auto 36px; }
  .ctc__title { font-size: 34px; margin-top: 16px; letter-spacing: -.03em; }
  .ctc__lead { font-size: 16px; margin-top: 12px; }

  .ctc__grid { display: grid; grid-template-columns: 320px 1fr; gap: 20px; align-items: stretch; }

  /* ---- Columna de datos (una sola tarjeta) ---- */
  .ctc__info { padding: 26px; display: flex; flex-direction: column; }
  .ctc__info-title { font-size: 16px; font-weight: 700; letter-spacing: -.01em; }
  .ctc__list { list-style: none; margin: 18px 0 0; padding: 0; display: flex; flex-direction: column; }
  .ctc__list li + li { border-top: 1px solid var(--line); }
  .ctc__row-item {
    display: flex; align-items: center; gap: 13px; padding: 15px 0;
    border-radius: var(--r-sm); transition: color .15s ease;
  }
  .ctc__row-item.is-link:hover .ctc__value { color: var(--brand); }
  .ctc__ic {
    width: 40px; height: 40px; border-radius: var(--r-sm); flex-shrink: 0;
    background: var(--brand-soft); display: grid; place-items: center;
  }
  .ctc__row-text { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .ctc__label { font-size: 11.5px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--muted); }
  .ctc__value { font-size: 14.5px; font-weight: 600; color: var(--ink); transition: color .15s ease; overflow-wrap: anywhere; }
  .ctc__info-note { font-size: 13px; line-height: 1.5; margin: auto 0 0; padding-top: 18px; }

  /* ---- Formulario ---- */
  .ctc__form { padding: 26px; display: grid; gap: 15px; align-content: start; }
  .ctc__form-title { font-size: 16px; font-weight: 700; letter-spacing: -.01em; margin-bottom: 3px; }
  .ctc__row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
  .ctc__f { display: block; }
  .ctc__actions { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: 5px; }
  .ctc__note { font-size: 13px; margin: 0; line-height: 1.4; }
  .ctc__note[data-state='ok'] { color: var(--brand); font-weight: 600; }
  .ctc__note[data-state='error'] { color: var(--danger); font-weight: 600; }

  @media (max-width: 900px) {
    .ctc__grid { grid-template-columns: 1fr; }
    .ctc__info-note { margin-top: 4px; }
  }
  @media (max-width: 520px) {
    .ctc__title { font-size: 27px; }
    .ctc__row { grid-template-columns: 1fr; }
    .ctc__info, .ctc__form { padding: 20px; }
  }
</style>

<script>
  // Formulario de contacto sin backend: se valida en el cliente y se muestra una
  // confirmación. El envío real por correo se hará donde está el TODO.
  // Enlazado por-instancia e idempotente ante navegaciones (guard con data-attr).
  function initContactForm() {
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    if (!form || form.hasAttribute('data-contact-ready')) return;
    form.setAttribute('data-contact-ready', '');

    const status = form.querySelector<HTMLParagraphElement>('[data-contact-status]');
    const submit = form.querySelector<HTMLButtonElement>('[data-contact-submit]');

    const setStatus = (msg: string, state: '' | 'ok' | 'error') => {
      if (!status) return;
      status.textContent = msg;
      if (state) status.setAttribute('data-state', state);
      else status.removeAttribute('data-state');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus('Revisa los campos marcados.', 'error');
        return;
      }

      const data = Object.fromEntries(new FormData(form).entries());
      if (submit) submit.disabled = true;
      setStatus('Enviando…', '');

      try {
        // TODO: enviar `data` al endpoint de correo cuando exista, p. ej.:
        //   await fetch('/api/contact', {
        //     method: 'POST',
        //     headers: { 'Content-Type': 'application/json' },
        //     body: JSON.stringify(data),
        //   });
        // De momento no hay backend: solo confirmamos en pantalla.
        void data;
        form.reset();
        setStatus('¡Gracias! Recibimos tu mensaje y te contactaremos pronto.', 'ok');
      } catch {
        setStatus('No pudimos enviar tu mensaje. Escríbenos a info@hsgloballtd.com.', 'error');
      } finally {
        if (submit) submit.disabled = false;
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>

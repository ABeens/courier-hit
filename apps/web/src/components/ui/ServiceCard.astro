---
/*
  ServiceCard — tarjeta de servicio del landing. No navega: los servicios se
  presentan completos en la propia sección, sin páginas de detalle.
*/
import Icon from './Icon.astro';
import type { Service } from '../../data/services';

interface Props {
  service: Service;
}
const { service } = Astro.props;
---
<article class="card svc">
  <div class="between">
    <span class="svc__ic"><Icon name={service.icon} size={23} color="var(--brand)" /></span>
    {service.tag && <span class="svc__tag">{service.tag}</span>}
  </div>
  <div class="svc__name">{service.name}</div>
  <p class="muted svc__short">{service.short}</p>
</article>

<style>
  .svc { padding: 24px; text-align: left; display: block; }
  .svc__ic {
    width: 48px; height: 48px; border-radius: 13px; background: var(--brand-soft);
    display: grid; place-items: center;
  }
  .svc__tag {
    font-size: 11px; font-weight: 700; color: var(--brand-600);
    background: var(--brand-soft); padding: 4px 10px; border-radius: 99px;
  }
  .svc__name { font-weight: 700; font-size: 17px; margin-top: 18px; font-family: var(--font-display); }
  .svc__short { font-size: 14px; margin-top: 8px; line-height: 1.55; }
</style>

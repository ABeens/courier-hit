interface Props {
  name: keyof typeof ICONS | string;
  size?: number;
  color?: string;
  strokeWidth?: number;
  class?: string;
}

const { name, size = 18, color, strokeWidth = 2, class: className } = Astro.props;
const raw = ICONS[name];
const parts = raw ? raw.split('|') : [];
---
{raw && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke={color ?? 'currentColor'}
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
  >
    {parts.map((p) => {
      if (p.startsWith('o ')) {
        const [, cx, cy, r] = p.split(' ');
        return <circle cx={cx} cy={cy} r={r} />;
      }
      return <path d={p} />;
    })}
  </svg>
)}

---
/*
  Logo — marca oficial HS Global (imagen: /public/logo.png) + wordmark a la
  derecha, como en el prototipo.
  - size: alto de la imagen en px (el texto escala a partir de ahí).
  - dark: sobre fondos oscuros la imagen va en pastilla blanca y el texto en blanco.
*/
interface Props {
  size?: number;
  dark?: boolean;
  class?: string;
}
const { size = 40, dark = false, class: className } = Astro.props;

// Relación de aspecto real del archivo (1145 × 961).
const ratio = 1145 / 961;
const h = size;
const w = Math.round(size * ratio);

const fg = dark ? '#fff' : 'var(--ink)';
const accent = 'var(--brand)';
---
<div class:list={['logo', className]} style={`--logo-h:${size}px`}>
  <img
    src="/logo.png"
    alt=""
    width={w}
    height={h}
    class:list={['logo__img', { 'logo__img--dark': dark }]}
    decoding="async"
  />
  <div class="logo__text">
    <div class="logo__name" style={`color:${fg}`}>HS Global</div>
    <div class="logo__sub" style={`color:${accent}`}>Courier</div>
  </div>
</div>

<style>
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo__img {
    height: var(--logo-h);
    width: auto;
    display: block;
    object-fit: contain;
    flex-shrink: 0;
  }
  .logo__img--dark {
    background: #fff;
    border-radius: 10px;
    padding: 6px 10px;
    box-sizing: content-box;
  }
  .logo__text { line-height: 1; font-family: var(--font-display); }
  .logo__name {
    font-size: calc(var(--logo-h) * 0.42);
    font-weight: 700; letter-spacing: -0.02em;
  }
  .logo__sub {
    font-size: calc(var(--logo-h) * 0.24);
    font-weight: 600; letter-spacing: 0.18em; margin-top: 3px; text-transform: uppercase;
  }
</style>

# Entorno de la API. Copiar a .env y ajustar.
NODE_ENV=development
PORT=3001

# Postgres (Amazon RDS en prod). Formato: postgres://user:pass@host:puerto/db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/courier

# Origen del sitio web (para CORS). Astro dev por defecto:
WEB_ORIGIN=http://localhost:4321

# Sesion (cookie httpOnly)
SESSION_COOKIE_NAME=hs_session
SESSION_TTL_HOURS=168

# Codigo de verificacion por email
EMAIL_CODE_TTL_MINUTES=15
EMAIL_CODE_MAX_ATTEMPTS=5

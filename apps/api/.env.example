# Entorno de la API. Copiar a .env y ajustar.
NODE_ENV=development
PORT=3001

# Postgres (Amazon RDS en prod). Formato: postgres://user:pass@host:puerto/db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/courier

# Origen del sitio web (para CORS). Astro dev por defecto:
WEB_ORIGIN=http://localhost:4321

# Sesion (cookie httpOnly)
SESSION_COOKIE_NAME=hs_session
SESSION_TTL_HOURS=168

# Codigo de verificacion por email
EMAIL_CODE_TTL_MINUTES=15
EMAIL_CODE_MAX_ATTEMPTS=5

# Invitacion de staff: horas de validez del token para fijar contrasena
INVITE_TTL_HOURS=72

# --- Proveedor de casillero en Miami: Helga (docs/13) ---
# Apagado en desarrollo: la IP local no esta en la lista blanca del proveedor.
# Con HELGA_ENABLED=true, las demas (salvo APP_ID y TIMEOUT) son obligatorias.
HELGA_ENABLED=false
HELGA_BASE_URL=https://<ambiente>.helgasys.com
HELGA_CLIENT_ID=11
HELGA_CLIENT_SECRET=
HELGA_USERNAME=servicioalcliente@hsglobal-services.com
HELGA_PASSWORD=
HELGA_APP_ID=
# Origin registrado en la lista blanca; sin el, Helga responde 403.
HELGA_ORIGIN=
HELGA_TIMEOUT_MS=15000

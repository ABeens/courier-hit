# Entorno de la API. Copiar a .env y ajustar.
NODE_ENV=development
PORT=3001

# Postgres (Amazon RDS en prod). Formato: postgres://user:pass@host:puerto/db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/courier

# Origen del sitio web (para CORS). Astro dev por defecto:
WEB_ORIGIN=http://localhost:4321

# Sesion (cookie httpOnly)
SESSION_COOKIE_NAME=hs_session
SESSION_TTL_HOURS=168

# Codigo de verificacion por email
EMAIL_CODE_TTL_MINUTES=15
EMAIL_CODE_MAX_ATTEMPTS=5

# Invitacion de staff: horas de validez del token para fijar contrasena
INVITE_TTL_HOURS=72

# --- Proveedor de casillero en Miami: Helga (docs/13) ---
# Con HELGA_ENABLED=true, las demas (salvo APP_ID y TIMEOUT) son obligatorias.
# Encenderlo solo desde una IP que el proveedor tenga en su lista blanca.
HELGA_ENABLED=false
HELGA_BASE_URL=https://lmexpress.helgasys.com
HELGA_CLIENT_ID=11
HELGA_CLIENT_SECRET=
HELGA_USERNAME=servicioalcliente@hsglobal-services.com
HELGA_PASSWORD=
HELGA_APP_ID=
# Origin registrado en la lista blanca; sin el, Helga responde 403.
HELGA_ORIGIN=https://lmexpress.helgasys.com
HELGA_TIMEOUT_MS=15000

# --- Tasa de cambio sugerida: indicadores economicos del BCCR ---
# Solo SUGIERE la tasa del dia en la pantalla de costos; el operador la digita y
# esa es la que se guarda. Apagada, el campo simplemente arranca vacio: no se
# pierde ninguna funcion.
#
# INTERRUPTOR LIBRE: a diferencia de Helga, encender esta bandera SIN credenciales
# no impide arrancar. La API avisa por consola y se comporta como si estuviera
# apagada. Asi se puede dejar en true desde ya e ir llenando las credenciales.
BCCR_ENABLED=false
BCCR_BASE_URL=https://gee.bccr.fi.cr/Indicadores/Suscripciones/WS/wsindicadoreseconomicos.asmx/ObtenerIndicadoresEconomicos
# 318 = tipo de cambio de VENTA del dolar (el que se le cobra al cliente)
BCCR_INDICATOR=318
# Nombre, correo y token de la suscripcion al web service del BCCR
BCCR_NAME=
BCCR_EMAIL=
BCCR_TOKEN=
BCCR_TIMEOUT_MS=8000
